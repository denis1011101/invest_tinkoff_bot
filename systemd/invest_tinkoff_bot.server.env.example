# Server (runs market-cache-refresh.timer and cache-health.timer).
# Copy to /etc/invest_tinkoff_bot.env and set permissions:
#   sudo install -m 0600 -o root -g root systemd/invest_tinkoff_bot.server.env.example /etc/invest_tinkoff_bot.env
# Never create a working invest_tinkoff_bot.env inside the repository.
# MOEX_SYNC_* variables are NOT needed on the server (sync is pushed from the local machine).

TINKOFF_TOKEN=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Market cache refresh
# Keep SCAN_MAX_LOT_RUB >= MAX_LOT_RUB used by the strategy, otherwise valid
# instruments are silently dropped at cache stage (code default is only 500).
SCAN_MAX_LOT_RUB=2000
INSTRUMENT_CACHE_HOURS=24
MARKET_CACHE_SLEEP=

# Cache health watchdog thresholds
CACHE_WARN_AGE_HOURS=36
CACHE_CRITICAL_AGE_HOURS=60
INTERSECTION_CACHE_MAX_AGE_HOURS=72
CACHE_ALERT_REPEAT_HOURS=12

# Daily trade report (bin/daily_trade_report.rb, cron at 16:05 UTC = 21:05 YEKT).
# Rolling-24h window ending at the cutoff; reuses TELEGRAM_* above unless overridden.
DAILY_REPORT_UTC_OFFSET=+05:00
DAILY_REPORT_TIME_LABEL=YEKT
DAILY_REPORT_CUTOFF=21:00
DAILY_REPORT_INDEX=IMOEX
