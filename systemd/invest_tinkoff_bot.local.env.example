# Local machine (runs moex-cache-sync.timer, can reach MOEX ISS).
# Copy to /etc/invest_tinkoff_bot.env and set permissions:
#   sudo install -m 0600 -o root -g root systemd/invest_tinkoff_bot.local.env.example /etc/invest_tinkoff_bot.env
# Never create a working invest_tinkoff_bot.env inside the repository.
# TINKOFF_TOKEN is NOT needed on the local machine.

# Server deployment currently lives under root in /root/apps (matches cron).
MOEX_SYNC_HOST=
MOEX_SYNC_USER=root
MOEX_SYNC_REMOTE_DIR=/root/apps/invest_tinkoff_bot
MOEX_SYNC_SSH_KEY=/home/denis/.ssh/moex_sync

# Artifact validation limits (optional overrides)
MOEX_CACHE_MIN_INSTRUMENTS=20
MOEX_CACHE_MAX_AGE_HOURS=6
MOEX_CACHE_MIN_COUNT_RATIO=0.5
