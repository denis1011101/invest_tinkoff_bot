# Required
TINKOFF_TOKEN=your_token_here

# Telegram confirmation (optional; set AUTO_CONFIRM=1 to skip)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
AUTO_CONFIRM=0

# Universe / order sizing
TICKERS=SBER,ROSN,VTBR
MAX_LOT_RUB=1000.0          # max order cost (price_per_lot * lots_per_order)
MAX_LOT_COUNT=1              # skip instruments where lot > this value
LOTS_PER_ORDER=1             # order quantity in lots; shares = lot_size * LOTS_PER_ORDER
DIP_PCT=0.01                 # buy only when cur <= today_high * (1 - DIP_PCT)

# Sell thresholds (profit multiplier per market trend)
SELL_THRESHOLD_UP=1.10       # +10% in up trend
SELL_THRESHOLD_SIDE=1.04     # +4%  in side trend
SELL_THRESHOLD_DOWN=1.02     # +2%  in down trend

# Risk management
MAX_POSITION_SHARE=0.33      # block BUY if post-trade position > 33% of share portfolio

# Volume filters
MIN_RELATIVE_VOLUME=         # leave blank to disable (e.g. 1.5 = require 1.5x avg volume)
VOLUME_LOOKBACK_DAYS=20      # lookback N for average daily volume
VOLUME_COMPARE_MODE=none     # none | relative | turnover

# Market cache
SCAN_MAX_LOT_RUB=2000        # cache-time filter; keep >= MAX_LOT_RUB
INSTRUMENT_CACHE_HOURS=24    # cache TTL in hours; keep refresh cadence below stale-cache guard
MARKET_CACHE_SLEEP=          # optional sleep (seconds) between last_prices batches

# MOEX cache sync / validation
MOEX_SYNC_HOST=
MOEX_SYNC_USER=
MOEX_SYNC_REMOTE_DIR=/home/denis/my/invest_tinkoff_bot
MOEX_SYNC_SSH_KEY=
MOEX_CACHE_MIN_INSTRUMENTS=20
MOEX_CACHE_MAX_AGE_HOURS=6
MOEX_CACHE_MIN_COUNT_RATIO=0.5

# Cache health watchdog
CACHE_WARN_AGE_HOURS=36
CACHE_CRITICAL_AGE_HOURS=60
INTERSECTION_CACHE_MAX_AGE_HOURS=72
CACHE_ALERT_REPEAT_HOURS=12

# State management
BUY_PENDING_COOLDOWN_MIN=10  # cooldown (minutes) before retrying a pending BUY ticker
RESTORE_STATE_FROM_BROKER=1  # auto-restore empty state from broker on startup (set 0 to disable)
